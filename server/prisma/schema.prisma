generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  ADMIN
}

enum OrderStatus {
  NEW
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum ContactRequestStatus {
  NEW
  PROCESSED
}

model User {
  id           Int      @id @default(autoincrement())
  email        String   @unique
  passwordHash String
  name         String
  phone        String?
  role         Role     @default(USER)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  orders       Order[]
}

model Order {
  id          Int         @id @default(autoincrement())
  service     String
  status      OrderStatus @default(NEW)
  region      String
  budget      String
  timeline    String?
  description String
  wishes      String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  userId      Int
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ContactRequest {
  id        Int                  @id @default(autoincrement())
  name      String
  email     String
  phone     String
  message   String?
  consent   Boolean              @default(true)
  status    ContactRequestStatus @default(NEW)
  createdAt DateTime             @default(now())
  updatedAt DateTime             @updatedAt
}
